#include <avr/sleep.h>
#include <avr/power.h>
#include <avr/wdt.h>

// === Uncomment to enable test mode (forces night + very active eyes) ===
// #define TEST_MODE

// Pins
const byte LEFT_LED  = 1;  // PB1 – physical pin 6 on ATtiny85
const byte RIGHT_LED = 0;  // PB0 – physical pin 5 on ATtiny85
const byte LDR_PIN   = A3;

// Settings
const byte MAX_BRIGHTNESS = 255;
const byte NORMAL_BRIGHT  = 100;     // softer for realism
const int  NIGHT_THRESHOLD = 400;
const byte BLINK_CHANCE    = 12;     // slightly more frequent than before
const int  ACTIVE_CYCLES   = 1800;   // ~4 hours

volatile bool watchdogFired = false;
bool nightStarted = false;
int nightCounter = 0;

// Watchdog interrupt
ISR(WDT_vect) {
  watchdogFired = true;
}

void setupWatchdog() {
  MCUSR = 0;
  WDTCR = _BV(WDCE) | _BV(WDE);
  WDTCR = _BV(WDIE) | _BV(WDP3) | _BV(WDP0); // ~8s interval
}

void sleep8s() {
  watchdogFired = false;
  set_sleep_mode(SLEEP_MODE_PWR_DOWN);
  sleep_enable();
  power_adc_disable();
  power_timer1_disable();
  power_usi_disable();
  sleep_cpu();
  sleep_disable();
  power_all_enable();
}

bool isNight() {
#ifdef TEST_MODE
  return true;
#else
  power_adc_enable();
  int val = analogRead(LDR_PIN);
  power_adc_disable();
  return (val < NIGHT_THRESHOLD);
#endif
}

// ────────────────────────────────────────────────
// Smooth breathing (eyes "opening up" slowly)
// durationMs ≈ time for full cycle (fade in + hold + fade out)
// ────────────────────────────────────────────────
void breathing(byte pin, int durationMs = 4500, byte peakBright = 110) {
  analogWrite(pin == LEFT_LED ? RIGHT_LED : LEFT_LED, 0);  // other eye off

  int steps = 60;                    // smooth enough on 8-bit PWM
  int fadeTime = durationMs / 3;     // ~1/3 fade in, 1/3 hold, 1/3 fade out
  int stepDelay = fadeTime / steps;

  // Fade in
  for (int i = 0; i <= steps; i++) {
    byte b = map(i, 0, steps, 0, peakBright);
    analogWrite(pin, b);
    delay(stepDelay);
  }

  // Hold peak
  delay(fadeTime);

  // Fade out
  for (int i = steps; i >= 0; i--) {
    byte b = map(i, 0, steps, 0, peakBright);
    analogWrite(pin, b);
    delay(stepDelay);
  }

  analogWrite(pin, 0);  // ensure off
}

// Quick single blink (realistic short eyelid close)
void quickBlink(byte pin, byte bright = NORMAL_BRIGHT) {
  analogWrite(pin == LEFT_LED ? RIGHT_LED : LEFT_LED, 0); // other off

  analogWrite(pin, bright);
  delay(80);
  analogWrite(pin, 0);
  delay(120);
  analogWrite(pin, bright);
  delay(200);
  analogWrite(pin, 0);  // end off
}

// Synchronized blink (both eyes)
void bothQuickBlink() {
  analogWrite(LEFT_LED, 0);
  analogWrite(RIGHT_LED, 0);
  delay(100);

  analogWrite(LEFT_LED, NORMAL_BRIGHT);
  analogWrite(RIGHT_LED, NORMAL_BRIGHT);
  delay(150);
  analogWrite(LEFT_LED, 0);
  analogWrite(RIGHT_LED, 0);
}

// Combo with mix of blinks & breathing
void combo() {
  int r = random(5);
  if (r == 0) {
    breathing(LEFT_LED,  random(3000, 6000));
  } else if (r == 1) {
    breathing(RIGHT_LED, random(3000, 6000));
  } else if (r == 2) {
    quickBlink(LEFT_LED); delay(400); quickBlink(RIGHT_LED);
  } else if (r == 3) {
    quickBlink(RIGHT_LED); delay(300); bothQuickBlink();
  } else {
    breathing(LEFT_LED, 3500, 90); delay(600);
    breathing(RIGHT_LED, 4000, 100);
  }
}

void setup() {
  pinMode(LEFT_LED, OUTPUT);
  pinMode(RIGHT_LED, OUTPUT);
  pinMode(LDR_PIN, INPUT);

  randomSeed(analogRead(2));

  setupWatchdog();

  // Gentle startup – slow both-eye breath
  breathing(LEFT_LED,  3000, 180);
  breathing(RIGHT_LED, 3200, 180);
  analogWrite(LEFT_LED, 0);
  analogWrite(RIGHT_LED, 0);
  delay(800);

#ifdef TEST_MODE
  // Quick demo in test mode
  breathing(LEFT_LED, 4000);
  delay(800);
  quickBlink(RIGHT_LED);
  delay(800);
  combo();
#endif
}

void loop() {
  sleep8s();

  bool night = isNight();

  if (night && !nightStarted) {
    nightStarted = true;
    nightCounter = 0;

#ifdef TEST_MODE
    combo();
    delay(800);
    breathing(RIGHT_LED, 3800);
    delay(1000);
#endif
  }

  if (!night) {
    nightStarted = false;
    analogWrite(LEFT_LED, 0);
    analogWrite(RIGHT_LED, 0);
    return;
  }

  if (nightCounter > ACTIVE_CYCLES) return;
  nightCounter++;

#ifdef TEST_MODE
  if (random(3) == 0) return;   // ~66% animate chance → lively
#else
  if (random(BLINK_CHANCE) != 0) return;
#endif

  // Main random choice – more realistic mix
  int choice = random(10);
  if (choice < 3) {           // 30% breathing (slow open/close)
    if (random(2) == 0)
      breathing(LEFT_LED, random(3500, 6500), random(70, 130));
    else
      breathing(RIGHT_LED, random(3500, 6500), random(70, 130));
  }
  else if (choice < 6) {      // 30% single quick blink
    if (random(2) == 0)
      quickBlink(LEFT_LED);
    else
      quickBlink(RIGHT_LED);
  }
  else if (choice < 8) {      // 20% combo
    combo();
  }
  else {                      // 20% both blink
    bothQuickBlink();
  }
}
